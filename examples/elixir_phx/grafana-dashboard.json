{
  "dashboard": {
    "id": null,
    "title": "Elixir Phoenix Dice - Metrics to Traces",
    "tags": ["elixir", "otel", "traces"],
    "timezone": "browser",
    "refresh": "5s",
    "schemaVersion": 30,
    "version": 1,
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "panels": [
      {
        "id": 1,
        "title": "Dice Roll Rate (per second)",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "rate(dice_rolls_total[1m])",
            "interval": "",
            "legendFormat": "{{sides}}-sided ({{result_range}})",
            "refId": "A"
          }
        ],
        "links": [
          {
            "title": "View Traces for High Activity",
            "url": "/explore?left=[\"${__from}\",\"${__to}\",\"Tempo\",{\"queries\":[{\"refId\":\"A\",\"query\":\"{service.name=\\\"elixir-phx-dice-server\\\"}\"}]}]",
            "targetBlank": true
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 1,
              "fillOpacity": 0,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "auto",
              "pointSize": 5
            },
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "visible",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 2,
        "title": "Processing Time - 95th Percentile",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dice_processing_time_simple_bucket[1m]))",
            "interval": "",
            "legendFormat": "{{sides}}-sided dice",
            "refId": "A"
          }
        ],
        "links": [
          {
            "title": "View Slow Traces",
            "url": "/explore?left=[\"${__from}\",\"${__to}\",\"Tempo\",{\"queries\":[{\"refId\":\"A\",\"query\":\"{service.name=\\\"elixir-phx-dice-server\\\"} | duration > 100ms\"}]}]",
            "targetBlank": true
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "lineWidth": 1,
              "fillOpacity": 0,
              "gradientMode": "none",
              "spanNulls": false,
              "insertNulls": false,
              "showPoints": "auto",
              "pointSize": 5
            },
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "visible",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 3,
        "title": "High Latency Requests (>100ms)",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "increase(dice_processing_time_simple_bucket{le=\"+Inf\"}[1m]) - increase(dice_processing_time_simple_bucket{le=\"100\"}[1m])",
            "interval": "",
            "legendFormat": "{{sides}}-sided dice",
            "refId": "A"
          }
        ],
        "links": [
          {
            "title": "Debug Slow Requests",
            "url": "/explore?left=[\"${__from}\",\"${__to}\",\"Tempo\",{\"queries\":[{\"refId\":\"A\",\"query\":\"{service.name=\\\"elixir-phx-dice-server\\\"} | duration > 100ms\"}]}]",
            "targetBlank": true
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "fillOpacity": 80,
              "gradientMode": "none"
            },
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "visible",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 4,
        "title": "Current Active Traces (Live)",
        "type": "stat",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "targets": [
          {
            "expr": "sum(rate(dice_rolls_total[30s]))",
            "interval": "",
            "legendFormat": "Requests/sec",
            "refId": "A"
          }
        ],
        "links": [
          {
            "title": "View Current Traces",
            "url": "/explore?left=[\"now-5m\",\"now\",\"Tempo\",{\"queries\":[{\"refId\":\"A\",\"query\":\"{service.name=\\\"elixir-phx-dice-server\\\"}\"}]}]",
            "targetBlank": true
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.5
                },
                {
                  "color": "red",
                  "value": 2
                }
              ]
            },
            "unit": "reqps"
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      }
    ]
  },
  "overwrite": true
}
